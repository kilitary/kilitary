# Base environment for Docker services. Copy .env.docker.example to .env for local overrides
# (APP_KEY, secrets). Run: docker compose run --rm app php artisan key:generate

APP_NAME=kilitary
APP_ENV=local
APP_DEBUG=true
APP_KEY=

APP_URL=http://kiltary:82

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=kilitary
DB_USERNAME=kilitary
DB_PASSWORD=kilitary_secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_DOMAIN=kiltary
SESSION_SECURE_COOKIE=false

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
