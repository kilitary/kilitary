# Optional: copy to project root as `.env` for Docker-only secrets and keys, or merge into your existing `.env`.
# Compose always sets DB_HOST=mysql and REDIS_HOST=redis for PHP services (overrides host-local values).
#
# For MySQL service env interpolation, set in a file Docker Compose reads (e.g. project `.env`):
#   DB_DATABASE, DB_USERNAME, DB_PASSWORD, MYSQL_ROOT_PASSWORD
# Defaults in docker-compose.yml match docker/defaults.env when unset.
#
# First-time Laravel in Docker:
#   docker compose up -d
#   docker compose exec app php artisan key:generate --force
#   docker compose exec app php artisan migrate --force

APP_NAME=kilitary
APP_ENV=local
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=kilitary
DB_USERNAME=kilitary
DB_PASSWORD=kilitary_secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

# Compose interpolation (root `.env` or `docker compose --env-file ...`)
APP_PORT=8080
MYSQL_ROOT_PASSWORD=root_secret
DB_PORT_EXTERNAL=33060
REDIS_PORT_EXTERNAL=63790
